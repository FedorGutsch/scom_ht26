# --- Основные настройки приложения ---
PROJECT_NAME="AI SkillMatch Copilot"
DATABASE_URL="sqlite:///./app.db"
API_PREFIX="/api/v1"

# --- Настройки OpenRouter (LLM) ---
# Ваш секретный ключ (обязательно без кавычек, если в ключе нет пробелов)
OPENROUTER_API_KEY=sk-or-v1-key

# Модель, которую будет использовать ИИ. 
OPENROUTER_MODEL=tencent/hy3-preview:free

# Время ожидания ответа от ИИ (в секундах).
OPENROUTER_TIMEOUT_SECONDS=30